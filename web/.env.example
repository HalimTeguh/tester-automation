DATABASE_URL="file:./dev.db"
JWT_SECRET="webqa-local-secret-change-in-production"

# AI provider (OpenCode Go / OpenAI-compatible)
OPENCODE_API_KEY=""
OPENCODE_BASE_URL="https://opencode.ai/zen/go/v1"
OPENCODE_MODEL="qwen-max"
# Catatan: gunakan model non-reasoning (qwen-max, qwen-plus) agar hemat token.
# Model reasoning (kimi-k2.6, deepseek-r1, qwq-32b, o1, o3) sering habiskan token untuk thinking
# sehingga respons akhir terpotong atau kosong. Jika ingin pakai reasoning model,
# tambahkan AI_MAX_TOKENS=16000 di bawah.
# Alternatif jika pakai OpenAI langsung:
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4o-mini"

# Batas token untuk analisis AI (opsional, default 8000 untuk non-reasoning, 12000 untuk reasoning)
# AI_MAX_TOKENS=16000
