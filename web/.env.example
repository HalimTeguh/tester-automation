DATABASE_URL="file:./dev.db"
JWT_SECRET="webqa-local-secret-change-in-production"

# AI provider (OpenCode Go / OpenAI-compatible)
OPENCODE_API_KEY=""
OPENCODE_BASE_URL="https://opencode.ai/zen/go/v1"
OPENCODE_MODEL="kimi-k2.6"
# Catatan: model yang tersedia di OpenCode: kimi-k2.6, kimi-k2.7-code, deepseek-v4-flash,
# deepseek-v4-pro, glm-5.2, glm-5.1, minimax-m3, minimax-m2.7, dll.
# Model reasoning (kimi-k2.6, deepseek-r1) sering habiskan token untuk thinking.
# Jika ingin pakai reasoning model, tambahkan AI_MAX_TOKENS=16000 di bawah.
# Alternatif jika pakai OpenAI langsung:
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4o-mini"

# Batas token untuk analisis AI (opsional, default 8000 untuk non-reasoning, 12000 untuk reasoning)
# AI_MAX_TOKENS=16000
